  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "automated-tasks agent hook notify"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "automated-tasks agent hook notify"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "automated-tasks agent hook notify"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "automated-tasks agent hook notify"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "automated-tasks agent hook notify"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "automated-tasks agent hook notify"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // empty' | grep -Eq '(^|[;&|(])[[:space:]]*java(8|17|21|25)[[:space:]]+(go|bun|npm|npx)([[:space:]]|$)' && { echo 'Hook: drop the javaNN prefix on go/bun/npm/npx; run it bare to avoid re-sandboxing (PTY/gpg/loopback).' >&2; exit 2; }; exit 0"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "automated-tasks agent hook stop"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "automated-tasks agent hook session-start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "automated-tasks agent hook notify"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "automated-tasks agent hook notify"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "automated-tasks agent hook notify"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "automated-tasks agent hook status-line"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "proxy.golang.org",
        "sum.golang.org",
        "repo.maven.apache.org",
        "repo1.maven.org",
        "maven.repository.redhat.com",
        "repository.jboss.org",
        "plugins.gradle.org",
        "services.gradle.org",
        "raw.githubusercontent.com",
        "github.com",
        "gitlab.cee.redhat.com",
        "pypi.org",
        "files.pythonhosted.org"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "/tmp",
        "/private/tmp",
        "~/Downloads",
        "~/Library/Caches/go-build",
        "~/.cache/go-build",
        "~/.cache/uv",
        "~/go/pkg/mod",
        "~/.m2/repository"
      ]
    },
    "excludedCommands": [
      "gh *",
      "glab",
      "glab *",
      "git push",
      "git push *",
      "git fetch",
      "git fetch *",
      "git commit",
      "git commit *",
      "git merge *",
      "git rebase *",
      "git cherry-pick *",
      "git revert *",
      "git tag *",
      "git verify-commit",
      "git verify-commit *",
      "git verify-tag",
      "git verify-tag *",
      "git add",
      "git add *",
      "git checkout *",
      "git restore *",
      "git stash",
      "git stash *",
      "go test",
      "go test *",
      "go mod tidy",
      "go mod tidy *",
      "go get",
      "go get *",
      "make test",
      "make test *",
      "make test-go *",
      "make test-it *",
      "make test-frontend *",
      "make check",
      "make check *",
      "make lint",
      "make lint *",
      "make build",
      "make build *",
      "make tidy",
      "make tidy *",
      "docker",
      "podman",
      "docker *",
      "podman *",
      "~/.claude/skills/mn-review/scripts/*"
    ]
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "remoteControlAtStartup": false
}
